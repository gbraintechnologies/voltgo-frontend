{
  "expo": {
    "name": "voltGo",
    "slug": "voltGo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/adaptive-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3EE06A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.voltgo.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "VoltGO uses Face ID for fast, secure sign-in."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyDex_IKWvqGX2MQOXi7jUqy264s4z2E8xo"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#3EE06A",
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.voltgo.app",
      "permissions": [
        "USE_FINGERPRINT",
        "USE_BIOMETRIC",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDex_IKWvqGX2MQOXi7jUqy264s4z2E8xo"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "VoltGO uses Face ID for fast, secure sign-in."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "VoltGO needs your location to find nearby riders and set your pickup point."
        }
      ],
      [
        "react-native-maps",
        {
          "androidGoogleMapsApiKey": "AIzaSyDex_IKWvqGX2MQOXi7jUqy264s4z2E8xo",
          "iosGoogleMapsApiKey": "AIzaSyDex_IKWvqGX2MQOXi7jUqy264s4z2E8xo"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1746ed99-8196-4cbd-8950-f76b3f99eaa8"
      }
    }
  }
}